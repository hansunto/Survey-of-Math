                            <cell>8</cell>
                            <cell>31 (Try Again)</cell>
                        </row>
                        <row>
                            <cell>Mod. Quota (<m>d=43</m>)</cell>
                            <cell>9.023</cell>
                            <cell>9.418</cell>
                            <cell>4.953</cell>
                            <cell>8.023</cell>
                            <cell>—</cell>
                        </row>
                        <row>
                            <cell>Apportionment</cell>
                            <cell>9</cell>
                            <cell>9</cell>
                            <cell>4</cell>
                            <cell>8</cell>
                            <cell>30</cell>
                        </row>
                    </tabular>
           </li>

            <li>
                    <p>
                        <strong>Adam's Method</strong> (using <m>d = 48</m>):
                    </p>
                    <tabular bottom="minor" top="minor" left="minor" right="minor">
                        <row header="yes">
                            <cell>Course</cell>
                            <cell>Intro</cell>
                            <cell>Intermed</cell>
                            <cell>College</cell>
                            <cell>Lib Arts</cell>
                            <cell>Total</cell>
                        </row>
                        <row>
                            <cell>Mod. Quota</cell>
                            <cell>8.083</cell>
                            <cell>8.437</cell>
                            <cell>4.437</cell>
                            <cell>7.187</cell>
                            <cell>—</cell>
                        </row>
                        <row>
                            <cell>Apportionment</cell>
                            <cell>9</cell>
                            <cell>9</cell>
                            <cell>5</cell>
