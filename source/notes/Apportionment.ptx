      <cell>Standard Quota</cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
    </row>
    <row>
      <cell>Lower Quota</cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
    </row>
    <row>
      <cell>Surplus</cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
    </row>
    <row>
      <cell>Apportioned Seats</cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell>100</cell>
    </row>
  </tabular>
</table>
<solution>
  <p>
  The following table demonstrates the apportionment using Hamilton's Method with a standard divisor of <m>SD=10,000/100=100</m>.
</p>
<table xml:id="table-hamilton-alabama1">
  <title>Hamilton's Method Apportionment</title>
  <tabular bottom="minor" top="minor" left="minor" right="minor">
    <row header="yes">
      <cell>Category</cell>
      <cell>State A</cell>
      <cell>State B</cell>
      <cell>State C</cell>
      <cell>State D</cell>
      <cell>Total</cell>
    </row>
    <row>
      <cell>Population</cell>
      <cell>936</cell>
      <cell>2,726</cell>
      <cell>2,603</cell>
      <cell>3,735</cell>
      <cell>10,000</cell>
    </row>
    <row>
      <cell>Standard Quota</cell>
      <cell>9.36</cell>
      <cell>27.26</cell>
      <cell>26.03</cell>
      <cell>37.35</cell>
      <cell>100.00</cell>
    </row>
    <row>
      <cell>Lower Quota</cell>
      <cell>9</cell>
