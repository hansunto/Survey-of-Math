                <cell>Enrollment</cell>
                <cell>388</cell>
                <cell>405</cell>
                <cell>213</cell>
                <cell>345</cell>
                <cell>1351</cell>
                </row>
                <row>
                <cell>Standard Quota</cell>
                <cell>8.6158</cell>
                <cell>8.9933</cell>
                <cell>4.7298</cell>
                <cell>7.6610</cell>
                <cell>30</cell>
                </row>
                <row>
                <cell>Lower Quota</cell>
                <cell>8</cell>
                <cell>8</cell>
                <cell>4</cell>
                <cell>7</cell>
                <cell>27</cell>
                </row>
                <row>
                <cell>Fractional Part</cell>
                <cell>0.6158</cell>
                <cell>0.9933</cell>
                <cell>0.7298</cell>
                <cell>0.6610</cell>
                <cell>—</cell>
                </row>
                <row>
                <cell>Surplus Row</cell>
                <cell>0</cell>
                <cell>+1</cell>
                <cell>+1</cell>
                <cell>+1</cell>
                <cell>+3</cell>
                </row>
                <row>
               <cell>Apportionment</cell>
               <cell>8</cell>
               <cell>9</cell>
               <cell>5</cell>
               <cell>8</cell>
               <cell>30</cell>
               </row>
             </tabular>
           </li>

            <li>
               <p>
                  <strong>Jefferson's Method</strong> (using <m>d = 42.5</m>):
               </p>
                    <tabular bottom="minor" top="minor" left="minor" right="minor">
                        <row header="yes">
                            <cell>Course</cell>
