    <row>
      <cell>Surplus</cell>
      <cell>+1</cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
      <cell></cell>
    </row>
    <row>
      <cell>Final Seats</cell>
      <cell>10</cell>
      <cell>27</cell>
